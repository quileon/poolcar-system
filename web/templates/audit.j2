{% extends "template.html" %}

{% block head %}
	<title>Audit Log - Poolcar</title>
{% endblock %}

{% block body %}
{% if let Some(err) = error %}
<div class="alert alert-danger border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert">
	<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 -960 960 960"><path d="M480-280q17 0 28.5-11.5T520-320q0-17-11.5-28.5T480-360q-17 0-28.5 11.5T440-320q0 17 11.5 28.5T480-280Zm-40-160h80v-240h-80v240Zm40 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>
	<div>{{ err }}</div>
</div>
{% endif %}

<!-- Page Header -->
<div class="d-flex flex-column">
	<h3 class="fw-bold text-dark">Audit Log</h3>
	<p class="text-dark-emphasis">See history of car/tracker movement.</p>
</div>

<!-- Filters Card -->
<div class="card border-0 shadow-sm mb-2">
	<div class="card-body p-4">
		<form class="row g-3 align-items-end" hx-get="/audit" hx-target="body" hx-swap="innerHTML">
			<!-- Filter Choice -->
			<div class="col-12 col-md-3">
				<label for="filter-choice" class="form-label fw-semibold text-muted">Filter Type</label>
				<select id="filter-choice" name="choice" class="form-select">
					<option value="tracker" {% if let Some(choice) = selected_choice %}{% if choice == "tracker" %}selected{% endif %}{% endif %}>Tracker</option>
					<option value="car" {% if let Some(choice) = selected_choice %}{% if choice == "car" %}selected{% endif %}{% endif %}>Car</option>
				</select>
			</div>

			<!-- Filter Target -->
			<div class="col-12 col-md-3">
				<label for="filter-target" class="form-label fw-semibold text-muted">Select Item</label>
				<select id="filter-target" name="target" class="form-select">
					<!-- Populated by JS -->
				</select>
			</div>

			<!-- Date Input -->
			<div class="col-12 col-md-3">
				<label for="filter-date" class="form-label fw-semibold text-muted">Date</label>
				<input type="date" id="filter-date" name="date" class="form-control">
			</div>

			<!-- Action Buttons -->
			<div class="col-12 col-md-3 d-flex gap-2">
				<button type="submit" class="btn btn-primary w-100">Filter</button>
				<a id="export-csv-btn" href="#" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2" hx-boost="false">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 -960 960 960"><path d="M480-320 280-520l56-58 104 104v-326h80v326l104-104 56 58-200 200ZM240-160q-33 0-56.5-23.5T160-240v-120h80v120h480v-120h80v120q0 33-23.5 56.5T720-160H240Z"/></svg>
					Export CSV
				</a>
			</div>
		</form>
	</div>
</div>

<!-- Map Container -->
<div class="rounded-4 overflow-hidden border border-secondary-subtle" style="height: calc(100vh - 380px); width: 100%; position: relative;">
	<div id="audit-map" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; z-index: 1;"></div>
</div>

<div id="audit-records-data" style="display: none;">
	{% for record in audit_records %}
		<div class="audit-point"
			 data-lat="{{ record.latitude }}"
			 data-lng="{{ record.longitude }}"
			 data-time="{{ record.time_wib }}">
		</div>
	{% endfor %}
</div>

<script>
(function() {
	function initMap() {
		const mapElement = document.getElementById('audit-map');
		if (!mapElement) return;

		const homeLat = -6.370901936057233;
		const homeLng = 106.82459298887727;
		const homeIcon = L.icon({
			iconUrl: '/assets/home.png',
			iconSize: [42, 42],
			iconAnchor: [21, 21],
			popupAnchor: [0, -15]
		});

		// Initialize Map
		if (window.auditMap) {
			try {
				window.auditMap.off();
				window.auditMap.remove();
			} catch (e) {
				console.error('Error removing map:', e);
			}
			window.auditMap = null;
		}

		const map = L.map('audit-map').setView([homeLat, homeLng], 13);
		window.auditMap = map;

		mapElement.addEventListener('htmx:beforeCleanupElement', function() {
			if (window.auditMap) {
				try {
					window.auditMap.off();
					window.auditMap.remove();
				} catch (e) {
					console.error('Error removing map:', e);
				}
				window.auditMap = null;
			}
		});

		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			maxZoom: 19,
			attribution: '© OpenStreetMap'
		}).addTo(map);

		L.marker([homeLat, homeLng], { icon: homeIcon }).addTo(map).bindPopup('Politeknik Negeri Jakarta');

		// Handle Dynamic Dropdown Options and Map Plotting
		const choiceEl = document.getElementById('filter-choice');
		const targetEl = document.getElementById('filter-target');
		const dateInput = document.getElementById('filter-date');
		const exportBtn = document.getElementById('export-csv-btn');

		const selectedChoice = {% if let Some(choice) = selected_choice %}"{{ choice }}"{% else %}null{% endif %};
		const selectedTarget = {% if let Some(target) = selected_target %}{{ target }}{% else %}null{% endif %};
		const selectedDate = {% if let Some(date) = selected_date %}"{{ date }}"{% else %}null{% endif %};

		const plainIcon = L.icon({
			iconUrl: '/assets/plain.png',
			iconSize: [25, 41],
			iconAnchor: [12.5, 41],
			popupAnchor: [0, -35]
		});

		function updateTargetOptions() {
			if (!choiceEl || !targetEl) return;
			const choice = choiceEl.value;
			targetEl.innerHTML = '';

			if (choice === 'tracker') {
				{% for tracker in trackers %}
					{
						const opt = document.createElement('option');
						opt.value = "{{ tracker.tracker_id }}";
						opt.textContent = "{{ tracker.name }}";
						if (selectedTarget && String(selectedTarget) === String(opt.value)) {
							opt.selected = true;
						}
						targetEl.appendChild(opt);
					}
				{% endfor %}
			} else if (choice === 'car') {
				{% for car in cars %}
					{
						const opt = document.createElement('option');
						opt.value = "{{ car.car_id }}";
						opt.textContent = "{{ car.name }} ({{ car.police_number }})";
						if (selectedTarget && String(selectedTarget) === String(opt.value)) {
							opt.selected = true;
						}
						targetEl.appendChild(opt);
					}
				{% endfor %}
			}
		}

		function updateExportLink() {
			if (!exportBtn || !choiceEl || !targetEl || !dateInput) return;
			const choice = choiceEl.value;
			const target = targetEl.value;
			const date = dateInput.value;
			exportBtn.href = `/audit/export?choice=${encodeURIComponent(choice)}&target=${encodeURIComponent(target)}&date=${encodeURIComponent(date)}`;
		}

		if (choiceEl && selectedChoice) {
			choiceEl.value = selectedChoice;
		}

		if (choiceEl && targetEl) {
			choiceEl.addEventListener('change', () => {
				updateTargetOptions();
				updateExportLink();
			});
			targetEl.addEventListener('change', updateExportLink);
			updateTargetOptions();
		}

		// Set default date to today
		const today = new Date().toISOString().split('T')[0];
		if (dateInput) {
			if (selectedDate) {
				dateInput.value = selectedDate;
			} else {
				dateInput.value = today;
			}
			dateInput.addEventListener('change', updateExportLink);
		}

		updateExportLink();

		// Plot Audit Points
		const auditPoints = document.querySelectorAll('.audit-point');
		const pathCoords = [];

		auditPoints.forEach((el, index) => {
			const latStr = el.getAttribute('data-lat');
			const lngStr = el.getAttribute('data-lng');
			const timeStr = el.getAttribute('data-time');

			if (latStr && lngStr) {
				const lat = parseFloat(latStr);
				const lng = parseFloat(lngStr);
				if (!isNaN(lat) && !isNaN(lng)) {
					const coord = [lat, lng];
					pathCoords.push(coord);

					L.marker(coord, { icon: plainIcon })
						.addTo(map)
						.bindPopup(`<strong>Point #${index + 1}</strong><br>Time: ${timeStr}`);
				}
			}
		});

		if (pathCoords.length > 0) {
			const polyline = L.polyline(pathCoords, { color: 'maroon', weight: 4, opacity: 0.7 }).addTo(map);
			map.fitBounds(polyline.getBounds(), { padding: [50, 50] });
		}

		map.invalidateSize();
	}

	const isHtmxSwap = document.querySelector('.htmx-swapping, .htmx-settling') !== null;
	if (isHtmxSwap) {
		document.body.addEventListener('htmx:afterSettle', function() {
			initMap();
		}, { once: true });
	} else {
		initMap();
	}
})();
</script>
{% endblock %}
