{% extends "template.html" %}

{% block head %}
	<title>Dashboard - Poolcar</title>
	<style>
		.icon-box {
			width: 60px;
			height: 60px;
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
		}
	</style>
{% endblock %}

{% block body %}
<div class="d-flex flex-column gap-4" style="height: calc(100vh - 140px);">
	<!-- Page Header -->
	<div class="flex-shrink-0">
		<h3 class="fw-bold text-dark">Dashboard</h3>
		<p class="text-dark-emphasis">Welcome back, {{ username }}</p>
	</div>

	<!-- Information Cards -->
	<div class="row g-4 flex-shrink-0">
		<!-- Card 1: Active Activities -->
		<div class="col-3">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body p-4 d-flex align-items-center gap-3">
					<div class="icon-box text-bg-primary">
						<img src="/assets/trip_bold.svg" alt="Active Activities" width="40" height="40">
					</div>
					<div>
						<div class="text-dark-emphasis fw-semibold">Active Activities Today</div>
						<div class="fs-4 text-dark fw-bold">{{ active_activities_today }} <span class="fs-6 text-dark-emphasis fw-normal">/ {{ all_activities_today }} total</span></div>
					</div>
				</div>
			</div>
		</div>

		<!-- Card 2: Cars with Assigned Trackers -->
		<div class="col-3">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body p-4 d-flex align-items-center gap-3">
					<div class="icon-box text-bg-success">
						<img src="/assets/cars_bold.svg" alt="Cars" width="40" height="40">
					</div>
					<div>
						<div class="text-dark-emphasis fw-semibold">Cars with Assigned Trackers</div>
						<div class="fs-4 text-dark fw-bold">{{ assigned_cars }} <span class="fs-6 text-dark-emphasis fw-normal">/ {{ all_cars }} cars</span></div>
					</div>
				</div>
			</div>
		</div>

		<!-- Card 3: Total Trackers -->
		<div class="col-3">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body p-4 d-flex align-items-center gap-3">
					<div class="icon-box text-bg-warning">
						<img src="/assets/trackers_bold.svg" alt="Total Trackers" width="40" height="40">
					</div>
					<div>
						<div class="text-dark-emphasis fw-semibold">Total Trackers</div>
						<div class="fs-4 text-dark fw-bold">{{ total_trackers }}</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Card 4: Car History -->
		<div class="col-3">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body p-4 d-flex align-items-center gap-3">
					<div class="icon-box text-bg-info">
						<img src="/assets/car_history_bold.svg" alt="Car Checks Today" width="24" height="24">
					</div>
					<div>
						<div class="text-dark-emphasis fw-semibold">Car History</div>
						<div class="fs-4 text-dark fw-bold">{{ car_checks_today }}</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Main Row -->
	<div class="row g-4 flex-grow-1">
		<!-- Left Side: Recent Activities -->
		<div class="col-4 d-flex flex-column" style="height: 100%; min-height: 0;">
			<div class="card border-0 shadow-sm flex-grow-1 d-flex flex-column overflow-hidden p-4">
				<div class="card-header border-0 bg-transparent p-0 mb-2 flex-shrink-0">
					<h5 class="fw-bold text-dark mb-0">Recent Activities</h5>
				</div>
				<div class="card-body flex-grow-1 p-0" style="overflow-y: auto; height: 0;">
					<div class="list-group list-group-flush">
						{% for activity in activities %}
						<div class="list-group-item py-3">
							<div class="d-flex align-items-center justify-content-between">
								{% if activity.is_active %}
								<span class="badge bg-primary-subtle text-primary rounded-pill">Active</span>
								{% else %}
								<span class="badge bg-success-subtle text-success rounded-pill">Completed</span>
								{% endif %}
								<small class="text-dark-emphasis">{{ activity.time_ago }}</small>
							</div>
							<h6 class="text-dark-emphasis mt-2 mb-1">Destination: <span class="fw-semibold">{{ activity.contact_name }}</span></h6>
							<p class="text-dark-emphasis m-0">Activity Type: <span class="fw-semibold">{{ activity.activity_type }}</span></p>
						</div>
						{% else %}
						<div class="text-muted text-center py-4">No recent activities found in the last week.</div>
						{% endfor %}
					</div>
				</div>
			</div>
		</div>

		<!-- Right Side: Dashboard Map -->
		<div class="col-8 d-flex flex-column">
			<div class="card border-0 shadow-sm flex-grow-1 d-flex flex-column overflow-hidden">
				<div class="card-body p-0 position-relative flex-grow-1" style="min-height: 350px;">
					<div id="dashboard-map" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; z-index: 1;"></div>
				</div>
			</div>
		</div>
	</div>
</div>

<div id="active-trips-data" style="display: none;">
	{% for trip in active_trips %}
		<div class="trip-destination"
			 data-activity-id="{{ trip.trip.activity_id }}"
			 data-lat="{{ trip.contact_latitude }}"
			 data-lng="{{ trip.contact_longitude }}">
		</div>
	{% endfor %}
</div>

<div id="trackers-data" style="display: none;">
	{% for tracker in trackers %}
		{% if let Some(payload) = self.get_payload(tracker.tracker.tracker_id) %}
			{% if let (Some(lat), Some(lng)) = (payload.location.latitude, payload.location.longitude) %}
				<div class="tracker-item"
					 data-tracker-id="{{ tracker.tracker.tracker_id }}"
					 data-name="{{ tracker.tracker.name }}"
					 data-car-name="{% if let Some(car) = tracker.car %}{{ car.name }} ({{ car.police_number }}){% endif %}"
					 data-lat="{{ lat }}"
					 data-lng="{{ lng }}"
					 data-car-type="{% if let Some(car) = tracker.car %}{{ car.car_type.as_str() }}{% else %}passenger{% endif %}">
				</div>
			{% endif %}
		{% endif %}
	{% endfor %}
</div>

<script>
(function() {
	function initMap() {
		const mapElement = document.getElementById('dashboard-map');
		if (!mapElement) return;

		const homeLat = -6.370901936057233;
		const homeLng = 106.82459298887727;
		const homeIcon = L.icon({
			iconUrl: '/assets/home.png',
			iconSize: [42, 42],
			iconAnchor: [21, 21],
			popupAnchor: [0, -15]
		});
		const colors = ['1d00ff', '00ff0e', 'cc0000', 'ff33e1', '0074cc', 'ffda00', 'ff8300', '28cc6a', 'ff3378', '00bdff'];

		// Initialize Map
		if (window.dashboardMap) {
			try {
				window.dashboardMap.off();
				window.dashboardMap.remove();
			} catch (e) {
				console.error('Error removing map:', e);
			}
			window.dashboardMap = null;
		}

		const map = L.map('dashboard-map').setView([homeLat, homeLng], 13);
		window.dashboardMap = map;

		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			maxZoom: 19,
			attribution: '© OpenStreetMap'
		}).addTo(map);

		// Home Marker
		L.marker([homeLat, homeLng], { icon: homeIcon }).addTo(map).bindPopup('Politeknik Negeri Jakarta');

		const markers = {};
		const destinationMarkers = {};
		const allLatLngs = [[homeLat, homeLng]];

		function recalculateBounds() {
			const newLatLngs = [[homeLat, homeLng]];
			for (const key in markers) {
				newLatLngs.push(markers[key].getLatLng());
			}
			for (const key in destinationMarkers) {
				newLatLngs.push(destinationMarkers[key].getLatLng());
			}
			allLatLngs.length = 0;
			newLatLngs.forEach(ll => allLatLngs.push(ll));
		}

		// Initialize Tracker Markers
		const trackerItems = document.querySelectorAll('.tracker-item');
		trackerItems.forEach(el => {
			const id = el.getAttribute('data-tracker-id');
			const name = el.getAttribute('data-name');
			const carName = el.getAttribute('data-car-name');
			const latStr = el.getAttribute('data-lat');
			const lngStr = el.getAttribute('data-lng');
			const carType = el.getAttribute('data-car-type') || 'passenger';

			if (latStr && lngStr) {
				const lat = parseFloat(latStr);
				const lng = parseFloat(lngStr);
				if (!isNaN(lat) && !isNaN(lng)) {
					const colorIndex = parseInt(id || '0');
					const color = colors[colorIndex % colors.length];
					const trackerIcon = L.icon({
						iconUrl: `/assets/${carType}-${color}.png`,
						iconSize: [31, 46],
						iconAnchor: [15.5, 46],
						popupAnchor: [0, -40]
					});

					const popupContent = carName ? `<strong>${name}</strong><br>${carName}` : `<strong>${name}</strong>`;
					const marker = L.marker([lat, lng], { icon: trackerIcon })
						.addTo(map)
						.bindPopup(popupContent);
					markers[id] = marker;
					allLatLngs.push([lat, lng]);
				}
			}
		});

		// Initialize Trip Destination Flags
		const tripDestinations = document.querySelectorAll('.trip-destination');
		tripDestinations.forEach(el => {
			const activityId = el.getAttribute('data-activity-id');
			const latStr = el.getAttribute('data-lat');
			const lngStr = el.getAttribute('data-lng');

			if (latStr && lngStr) {
				const lat = parseFloat(latStr);
				const lng = parseFloat(lngStr);
				if (!isNaN(lat) && !isNaN(lng)) {
					const flagIcon = L.icon({
						iconUrl: '/assets/flag.png',
						iconSize: [31, 46],
						iconAnchor: [15.5, 46],
						popupAnchor: [0, -40]
					});

					const marker = L.marker([lat, lng], { icon: flagIcon })
						.addTo(map)
						.bindPopup(`<strong>Destination</strong>`);

					if (activityId) {
						destinationMarkers[activityId] = marker;
					}
					allLatLngs.push([lat, lng]);
				}
			}
		});

		// Fit bounds initially if we have trackers/destinations
		if (allLatLngs.length > 1) {
			map.fitBounds(L.latLngBounds(allLatLngs), { padding: [50, 50] });
		}

		// Setup WebSocket
		const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
		const wsUrl = `${protocol}//${window.location.host}/ws/live`;
		const socket = new WebSocket(wsUrl);

		socket.onmessage = function(event) {
			try {
				const message = JSON.parse(event.data);
				if (message.message_type === 'tracker_location') {
					const payload = message.data;
					const trackerId = payload.id;

					if (payload.location && payload.location.latitude !== null && payload.location.longitude !== null) {
						const lat = payload.location.latitude;
						const lng = payload.location.longitude;

						let marker = markers[trackerId];
						if (marker) {
							marker.setLatLng([lat, lng]);
						} else {
							const trackerEl = document.querySelector(`.tracker-item[data-tracker-id="${trackerId}"]`);
							const name = trackerEl ? trackerEl.getAttribute('data-name') : 'Tracker ' + trackerId;
							const carName = trackerEl ? trackerEl.getAttribute('data-car-name') : '';
							const carType = trackerEl ? (trackerEl.getAttribute('data-car-type') || 'passenger') : 'passenger';
							const color = colors[trackerId % colors.length];

							const customIcon = L.icon({
								iconUrl: `/assets/${carType}-${color}.png`,
								iconSize: [31, 46],
								iconAnchor: [15.5, 46],
								popupAnchor: [0, -40]
							});

							const popupContent = carName ? `<strong>${name}</strong><br>${carName}` : `<strong>${name}</strong>`;
							marker = L.marker([lat, lng], { icon: customIcon })
								.addTo(map)
								.bindPopup(popupContent);
							markers[trackerId] = marker;
						}

						recalculateBounds();
					}
				} else if (message.message_type === 'update_destination') {
					const payload = message.data;
					const activityId = payload.activity_id;
					const lat = parseFloat(payload.contact_latitude);
					const lng = parseFloat(payload.contact_longitude);

					if (!isNaN(lat) && !isNaN(lng)) {
						let marker = destinationMarkers[activityId];
						if (marker) {
							marker.setLatLng([lat, lng]);
							marker.setPopupContent(`<strong>Destination</strong>`);
						} else {
							const flagIcon = L.icon({
								iconUrl: '/assets/flag.png',
								iconSize: [31, 46],
								iconAnchor: [15.5, 46],
								popupAnchor: [0, -40]
							});
							marker = L.marker([lat, lng], { icon: flagIcon })
								.addTo(map)
								.bindPopup(`<strong>Destination</strong>`);
							destinationMarkers[activityId] = marker;
						}
						recalculateBounds();
					}
				} else if (message.message_type === 'remove_destination') {
					const payload = message.data;
					const activityId = payload.activity_id;
					const marker = destinationMarkers[activityId];
					if (marker) {
						map.removeLayer(marker);
						delete destinationMarkers[activityId];
						recalculateBounds();
					}
				}
			} catch (e) {
				console.error('Error handling WebSocket message:', e);
			}
		};

		socket.onclose = function() {
			console.log('Dashboard WebSocket connection closed');
		};

		socket.onerror = function(err) {
			console.error('Dashboard WebSocket error:', err);
		};

		mapElement.addEventListener('htmx:beforeCleanupElement', function() {
			try {
				socket.close();
			} catch (e) {
				console.error('Error closing WebSocket:', e);
			}
		});

		map.invalidateSize();
	}

	const isHtmxSwap = document.querySelector('.htmx-swapping, .htmx-settling') !== null;
	if (isHtmxSwap) {
		document.body.addEventListener('htmx:afterSettle', function() {
			initMap();
		}, { once: true });
	} else {
		initMap();
	}
})();
</script>
{% endblock %}
