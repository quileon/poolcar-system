{% extends "template.html" %}

{% block head %}
    <title>Users - Poolcar</title>
{% endblock %}

{% block body %}
<!-- Page Header -->
<div class="d-flex flex-column">
	<h3 class="fw-bold text-dark">Users Management</h3>
	<p class="text-dark-emphasis">Manage employee and admin user accounts registered in the system.</p>
</div>

{% if let Some(err) = error %}
<div class="alert alert-danger border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert">
	<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 -960 960 960"><path d="M480-280q17 0 28.5-11.5T520-320q0-17-11.5-28.5T480-360q-17 0-28.5 11.5T440-320q0 17 11.5 28.5T480-280Zm-40-160h80v-240h-80v240Zm40 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>
	<div>{{ err }}</div>
</div>
{% endif %}

<!-- Main Content -->
<div class="row g-4">
	<!-- Users List Column -->
	<div class="col-12 col-lg-8">
		<div class="card border-0 shadow-sm p-4 h-100">
			<div class="d-flex align-items-center justify-content-between mb-4">
				<h5 class="mb-0 fw-bold text-dark">Registered Users</h5>
				<span class="badge rounded-pill bg-primary bg-opacity-10 text-primary py-2 px-3 fw-semibold">
				    {{ users.len() }} Accounts
				</span>
			</div>

			<div class="table-responsive">
				<table class="table align-middle mb-0">
					<thead class="table-light">
						<tr>
							<th style="width: 80px;">ID</th>
							<th>Full Name</th>
							<th>Username</th>
							<th>Email Address</th>
							<th>Role</th>
							<th style="width: 150px;" class="text-end">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% if users.is_empty() %}
						<tr>
							<td colspan="6" class="text-center py-5 text-muted">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor" class="mb-3 text-secondary" style="width: 48px; height: 48px;"><path d="M71.93-276.62q0-30.92 15.96-55.19 15.96-24.27 42.63-37.76 57.02-27.89 114.67-43.01 57.66-15.11 126.73-15.11 69.08 0 126.73 15.11 57.66 15.12 114.68 43.01 26.67 13.49 42.63 37.76 15.96 24.27 15.96 55.19v28.16q0 24.15-17.73 42.46-17.73 18.31-43.04 18.31H132.69q-25.3 0-43.03-17.73-17.73-17.74-17.73-43.04v-28.16Zm755.38 88.93h-90.85q7.54-13.77 11.5-29.31t3.96-31.46v-33.08q0-39.38-19.28-75.07-19.29-35.68-54.72-61.23 40.23 6 76.39 18.57 36.15 12.58 69 29.73 31 16.54 47.88 38.99 16.88 22.44 16.88 49.01v33.08q0 25.3-17.73 43.04-17.73 17.73-43.03 17.73ZM272.96-533.35q-41.03-41.03-41.03-98.96 0-57.92 41.03-98.96 41.04-41.04 98.96-41.04 57.93 0 98.96 41.04 41.04 41.04 41.04 98.96 0 57.93-41.04 98.96-41.03 41.04-98.96 41.04-57.92 0-98.96-41.04Zm403.22 0q-41.12 41.04-98.87 41.04-6.77 0-17.23-1.54-10.47-1.54-17.23-3.38 23.66-28.45 36.37-63.12 12.7-34.67 12.7-72 0-37.34-12.96-71.73-12.96-34.38-36.11-63.3 8.61-3.08 17.23-4 8.61-.93 17.23-.93 57.75 0 98.87 41.04 41.12 41.04 41.12 98.96 0 57.93-41.12 98.96ZM131.92-247.69h480v-28.93q0-12.53-6.27-22.3-6.26-9.77-19.88-17.08-49.38-25.46-101.69-38.58-52.31-13.11-112.16-13.11-59.84 0-112.15 13.11-52.31 13.12-101.69 38.58-13.62 7.31-19.89 17.08-6.27 9.77-6.27 22.3v28.93Zm296.5-328.12q23.5-23.5 23.5-56.5t-23.5-56.5q-23.5-23.5-56.5-23.5t-56.5 23.5q-23.5 23.5-23.5 56.5t23.5 56.5q23.5 23.5 56.5 23.5t56.5-23.5Zm-56.5 328.12Zm0-384.62Z"/></svg>
								<div class="fs-6 fw-semibold text-dark-emphasis mb-1">No Users Found</div>
								<div>Add a user on the right side to get started.</div>
							</td>
						</tr>
						{% else %}
							{% for item in users %}
							<tr id="user-row-{{ item.user_id }}">
								<td class="font-monospace fw-semibold">#{{ item.user_id }}</td>
								<td class="fw-semibold text-dark">{{ item.full_name }}</td>
								<td class="font-monospace">{{ item.username }}</td>
								<td class="text-muted">{{ item.email }}</td>
								<td>
									{% if let crate::entities::sea_orm_active_enums::UserRole::Admin = item.user_role %}
										<span class="badge bg-danger px-2 py-1 rounded-pill fw-semibold">Admin</span>
									{% else if let crate::entities::sea_orm_active_enums::UserRole::Security = item.user_role %}
										<span class="badge bg-warning text-dark px-2 py-1 rounded-pill fw-semibold">Security</span>
									{% else %}
										<span class="badge bg-success px-2 py-1 rounded-pill fw-semibold">Employee</span>
									{% endif %}
								</td>
								<td class="text-end">
									<div class="d-flex gap-2 justify-content-end">
										<button hx-get="/crud/users?edit={{ item.user_id }}&page={{ current_page }}" hx-target="body" hx-swap="innerHTML" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-2" title="Edit">
											<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor" style="width: 16px; height: 16px;"><path d="M200-200h50.46l409.46-409.46-50.46-50.46L200-250.46V-200Zm-23.84 60q-15.37 0-25.76-10.4-10.4-10.39-10.4-25.76v-69.3q0-14.63 5.62-27.89 5.61-13.26 15.46-23.11l506.54-506.31q9.07-8.24 20.03-12.73 10.97-4.5 23-4.5t23.3 4.27q11.28 4.27 19.97 13.58l48.85 49.46q9.31 8.69 13.27 20 3.96 11.31 3.96 22.62 0 12.07-4.12 23.03-4.12 10.97-13.11 20.04L296.46-161.08q-9.85 9.85-23.11 15.46-13.26 5.62-27.89 5.62h-69.3Zm584.22-570.15-50.23-50.23 50.23 50.23Zm-126.13 75.9-24.79-25.67 50.46 50.46-25.67-24.79Z"/></svg>
											Edit
										</button>
										<button class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-2"
											hx-delete="/crud/users/{{ item.user_id }}?page={{ current_page }}"
											hx-target="body"
											hx-swap="innerHTML"
											hx-confirm="Are you sure you want to delete user '{{ item.username }}'?"
											title="Delete"
											{% if item.username == username %}disabled{% endif %}>
											<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor" style="width: 16px; height: 16px;"><path d="M292.31-140q-29.83 0-51.07-21.24Q220-182.48 220-212.31V-720h-10q-12.75 0-21.37-8.63-8.63-8.63-8.63-21.38 0-12.76 8.63-21.37Q197.25-780 210-780h150q0-14.69 10.35-25.04 10.34-10.34 25.03-10.34h169.24q14.69 0 25.03 10.34Q600-794.69 600-780h150q12.75 0 21.37 8.63 8.63 8.63 8.63 21.38 0-12.76-8.63-21.37Q762.75-720 750-720h-10v507.69q0 29.83-21.24 51.07Q697.52-140 667.69-140H292.31ZM680-720H280v507.69q0 5.39 3.46 8.85t8.85 3.46h375.38q5.39 0 8.85-3.46t3.46-8.85V-720ZM427.54-288.62q8.61-8.63 8.61-21.38v-300q0-12.75-8.63-21.38-8.62-8.62-21.38-8.62-12.75 0-21.37 8.62-8.61 8.63-8.61 21.38v300q0 12.75 8.62 21.38 8.63 8.62 21.39 8.62 12.75 0 21.37-8.62Zm147.69 0q8.61-8.63 8.61-21.38v-300q0-12.75-8.62-21.38-8.63-8.62-21.39-8.62-12.75 0-21.37 8.62-8.61 8.63-8.61 21.38v300q0 12.75 8.63 21.38 8.62 8.62 21.38 8.62 12.75 0 21.37-8.62ZM280-720v520-520Z"/></svg>
											Delete
										</button>
									</div>
								</td>
							</tr>
							{% endfor %}
						{% endif %}
					</tbody>
				</table>
			</div>

			{% if total_pages > 1 %}
			<div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
				<div class="text-muted small">
					Page {{ current_page }} of {{ total_pages }}
				</div>
				<nav aria-label="Table navigation">
					<ul class="pagination pagination-sm mb-0">
						<!-- Previous Page -->
						<li class="page-item {% if current_page == 1 %}disabled{% endif %}">
							<button class="page-link"
								hx-get="/crud/users?page={{ current_page - 1 }}{% if let Some(e) = editing_user %}&edit={{ e.user_id }}{% endif %}"
								hx-target="body"
								hx-swap="innerHTML"
								{% if current_page == 1 %}disabled{% endif %}>
								Previous
							</button>
						</li>

						<!-- Page Numbers -->
						{% for p in pages %}
						<li class="page-item {% if *p == current_page %}active{% endif %}">
							<button class="page-link"
								hx-get="/crud/users?page={{ p }}{% if let Some(e) = editing_user %}&edit={{ e.user_id }}{% endif %}"
								hx-target="body"
								hx-swap="innerHTML">
								{{ p }}
							</button>
						</li>
						{% endfor %}

						<!-- Next Page -->
						<li class="page-item {% if current_page == total_pages %}disabled{% endif %}">
							<button class="page-link"
								hx-get="/crud/users?page={{ current_page + 1 }}{% if let Some(e) = editing_user %}&edit={{ e.user_id }}{% endif %}"
								hx-target="body"
								hx-swap="innerHTML"
								{% if current_page == total_pages %}disabled{% endif %}>
								Next
							</button>
						</li>
					</ul>
				</nav>
			</div>
			{% endif %}
		</div>
	</div>

	<!-- CRUD Form -->
	<div class="col-12 col-lg-4">
		<div class="card border-0 shadow-sm p-4 h-100 d-flex flex-column gap-4">
			{% if let Some(editing) = editing_user %}
				<div class="d-flex align-items-center justify-content-between">
					<h5 class="fw-bold text-dark">Edit User</h5>
					<span class="badge rounded-pill bg-primary px-3 py-2 fw-semibold">ID #{{ editing.user_id }}</span>
				</div>

				<form hx-put="/crud/users/{{ editing.user_id }}?page={{ current_page }}" hx-target="body" hx-swap="innerHTML">
					<div class="mb-3">
						<label for="user-fullname" class="form-label fw-semibold text-muted">Full Name</label>
						<input type="text" class="form-control form-control-lg" id="user-fullname" name="full_name" value="{{ editing.full_name }}" placeholder="e.g. John Doe" required>
					</div>
					<div class="mb-3">
						<label for="user-username" class="form-label fw-semibold text-muted">Username</label>
						<input type="text" class="form-control form-control-lg" id="user-username" name="username" value="{{ editing.username }}" placeholder="e.g. johndoe" required>
					</div>
					<div class="mb-3">
						<label for="user-email" class="form-label fw-semibold text-muted">Email Address</label>
						<input type="email" class="form-control form-control-lg" id="user-email" name="email" value="{{ editing.email }}" placeholder="e.g. john@example.com" required>
					</div>
					<div class="mb-3">
						<label for="user-password" class="form-label fw-semibold text-muted">Password (Optional)</label>
						<input type="password" class="form-control form-control-lg" id="user-password" name="password" placeholder="Leave blank to keep current password">
					</div>
					<div class="mb-3">
						<label for="user-role" class="form-label fw-semibold text-muted">User Role</label>
						<select class="form-select form-select-lg" id="user-role" name="user_role" required>
							<option value="Employee" {% if let crate::entities::sea_orm_active_enums::UserRole::Employee = editing.user_role %}selected{% endif %}>Employee</option>
							<option value="Security" {% if let crate::entities::sea_orm_active_enums::UserRole::Security = editing.user_role %}selected{% endif %}>Security</option>
							<option value="Admin" {% if let crate::entities::sea_orm_active_enums::UserRole::Admin = editing.user_role %}selected{% endif %}>Admin</option>
						</select>
					</div>
					<div class="d-grid gap-2">
						<button type="submit" class="btn btn-primary btn-lg fs-6">Save Changes</button>
						<button hx-get="/crud/users?page={{ current_page }}" hx-target="body" hx-swap="innerHTML" class="btn btn-light border btn-lg fs-6">Cancel</button>
					</div>
				</form>
			{% else %}
				<h5 class="fw-bold text-dark">Add New User</h5>

				<form hx-post="/crud/users" hx-target="body" hx-swap="innerHTML">
					<div class="mb-3">
						<label for="user-fullname" class="form-label fw-semibold text-muted">Full Name</label>
						<input type="text" class="form-control form-control-lg" id="user-fullname" name="full_name" placeholder="e.g. John Doe" required>
					</div>
					<div class="mb-3">
						<label for="user-username" class="form-label fw-semibold text-muted">Username</label>
						<input type="text" class="form-control form-control-lg" id="user-username" name="username" placeholder="e.g. johndoe" required>
					</div>
					<div class="mb-3">
						<label for="user-email" class="form-label fw-semibold text-muted">Email Address</label>
						<input type="email" class="form-control form-control-lg" id="user-email" name="email" placeholder="e.g. john@example.com" required>
					</div>
					<div class="mb-3">
						<label for="user-password" class="form-label fw-semibold text-muted">Password</label>
						<input type="password" class="form-control form-control-lg" id="user-password" name="password" placeholder="Enter secure password" required>
					</div>
					<div class="mb-3">
						<label for="user-role" class="form-label fw-semibold text-muted">User Role</label>
						<select class="form-select form-select-lg" id="user-role" name="user_role" required>
							<option value="Employee" selected>Employee</option>
							<option value="Security">Security</option>
							<option value="Admin">Admin</option>
						</select>
					</div>
					<div class="d-grid">
						<button type="submit" class="btn btn-primary btn-lg fs-6">Add User</button>
					</div>
				</form>
			{% endif %}
		</div>
	</div>
</div>
{% endblock %}
