{% extends "template.html" %}

{% block head %}
	<title>Audit Log - Poolcar</title>
{% endblock %}

{% block body %}
{% if let Some(err) = error %}
<div class="alert alert-danger border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert">
	<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 -960 960 960"><path d="M480-280q17 0 28.5-11.5T520-320q0-17-11.5-28.5T480-360q-17 0-28.5 11.5T440-320q0 17 11.5 28.5T480-280Zm-40-160h80v-240h-80v240Zm40 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>
	<div>{{ err }}</div>
</div>
{% endif %}

<!-- Page Header -->
<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
	<div>
		<h3 class="fw-bold text-dark mb-1">Audit Log</h3>
		<p class="text-muted mb-0">Track device and vehicle location history</p>
	</div>
</div>

<!-- Filters Card -->
<div class="card border-0 shadow-sm mb-4">
	<div class="card-body p-4">
		<form class="row g-3 align-items-end">
			<!-- Filter Choice -->
			<div class="col-12 col-md-3">
				<label for="filter-choice" class="form-label fw-semibold text-muted">Filter Type</label>
				<select id="filter-choice" class="form-select form-select-lg">
					<option value="tracker" selected>Tracker</option>
					<option value="car">Car</option>
				</select>
			</div>

			<!-- Filter Target -->
			<div class="col-12 col-md-3">
				<label for="filter-target" class="form-label fw-semibold text-muted">Select Item</label>
				<select id="filter-target" class="form-select form-select-lg">
					<!-- Populated by JS -->
				</select>
			</div>

			<!-- Date Input -->
			<div class="col-12 col-md-3">
				<label for="filter-date" class="form-label fw-semibold text-muted">Date</label>
				<input type="date" id="filter-date" class="form-control form-control-lg">
			</div>

			<!-- Action Buttons -->
			<div class="col-12 col-md-3 d-flex gap-2">
				<button type="button" class="btn btn-primary btn-lg w-100 fs-6">Filter</button>
				<button type="button" class="btn btn-outline-secondary btn-lg w-100 fs-6 d-flex align-items-center justify-content-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 -960 960 960"><path d="M480-320 280-520l56-58 104 104v-326h80v326l104-104 56 58-200 200ZM240-160q-33 0-56.5-23.5T160-240v-120h80v120h480v-120h80v120q0 33-23.5 56.5T720-160H240Z"/></svg>
					Export CSV
				</button>
			</div>
		</form>
	</div>
</div>

<!-- Map Container -->
<div class="rounded-4 overflow-hidden border border-secondary-subtle mb-4" style="height: calc(100vh - 410px); width: 100%; position: relative;">
	<div id="audit-map" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; z-index: 1;"></div>
</div>

<script>
(function() {
	function initMap() {
		const mapElement = document.getElementById('audit-map');
		if (!mapElement) return;

		const homeLat = -6.370901936057233;
		const homeLng = 106.82459298887727;
		const homeIcon = L.icon({
			iconUrl: '/assets/home.png',
			iconSize: [42, 42],
			iconAnchor: [21, 21],
			popupAnchor: [0, -15]
		});

		// Initialize Map
		if (window.auditMap) {
			try {
				window.auditMap.off();
				window.auditMap.remove();
			} catch (e) {
				console.error('Error removing map:', e);
			}
			window.auditMap = null;
		}

		const map = L.map('audit-map').setView([homeLat, homeLng], 13);
		window.auditMap = map;

		mapElement.addEventListener('htmx:beforeCleanupElement', function() {
			if (window.auditMap) {
				try {
					window.auditMap.off();
					window.auditMap.remove();
				} catch (e) {
					console.error('Error removing map:', e);
				}
				window.auditMap = null;
			}
		});

		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			maxZoom: 19,
			attribution: '© OpenStreetMap'
		}).addTo(map);

		L.marker([homeLat, homeLng], { icon: homeIcon }).addTo(map).bindPopup('Politeknik Negeri Jakarta');

		// Handle Dynamic Dropdown Options
		const choiceEl = document.getElementById('filter-choice');
		const targetEl = document.getElementById('filter-target');

		function updateTargetOptions() {
			if (!choiceEl || !targetEl) return;
			const choice = choiceEl.value;
			targetEl.innerHTML = '';

			if (choice === 'tracker') {
				{% for tracker in trackers %}
					{
						const opt = document.createElement('option');
						opt.value = "{{ tracker.tracker_id }}";
						opt.textContent = "{{ tracker.name }}";
						targetEl.appendChild(opt);
					}
				{% endfor %}
			} else if (choice === 'car') {
				{% for car in cars %}
					{
						const opt = document.createElement('option');
						opt.value = "{{ car.car_id }}";
						opt.textContent = "{{ car.name }} ({{ car.police_number }})";
						targetEl.appendChild(opt);
					}
				{% endfor %}
			}
		}

		if (choiceEl && targetEl) {
			choiceEl.addEventListener('change', updateTargetOptions);
			updateTargetOptions();
		}

		// Set default date to today
		const today = new Date().toISOString().split('T')[0];
		const dateInput = document.getElementById('filter-date');
		if (dateInput) {
			dateInput.value = today;
		}

		map.invalidateSize();
	}

	const isHtmxSwap = document.querySelector('.htmx-swapping, .htmx-settling') !== null;
	if (isHtmxSwap) {
		document.body.addEventListener('htmx:afterSettle', function() {
			initMap();
		}, { once: true });
	} else {
		initMap();
	}
})();
</script>
{% endblock %}
