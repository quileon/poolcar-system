{% extends "template.html" %}

{% block head %}
    <title>Cars - Poolcar</title>
{% endblock %}

{% block body %}
<!-- Page Header -->
<div class="d-flex flex-column">
	<h3 class="fw-bold text-dark">Cars Management</h3>
	<p class="text-dark-emphasis">Manage the vehicles registered in the system.</p>
</div>

{% if let Some(err) = error %}
<div class="alert alert-danger border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert">
	<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 -960 960 960"><path d="M480-280q17 0 28.5-11.5T520-320q0-17-11.5-28.5T480-360q-17 0-28.5 11.5T440-320q0 17 11.5 28.5T480-280Zm-40-160h80v-240h-80v240Zm40 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>
	<div>{{ err }}</div>
</div>
{% endif %}

<!-- Main Content -->
<div class="row g-4">
	<!-- Cars List Column -->
	<div class="col-12 col-lg-8">
		<div class="card border-0 shadow-sm p-4 h-100">
			<div class="d-flex align-items-center justify-content-between mb-4">
				<h5 class="mb-0 fw-bold text-dark">Registered Cars</h5>
				<span class="badge rounded-pill bg-primary bg-opacity-10 text-primary py-2 px-3 fw-semibold">
				    {{ cars.len() }} Vehicles
				</span>
			</div>

			<div class="table-responsive">
				<table class="table align-middle mb-0">
					<thead class="table-light">
						<tr>
							<th style="width: 80px;">ID</th>
							<th>Car Model</th>
							<th>License Plate</th>
							<th>Type</th>
							<th>Assigned Tracker</th>
							<th style="width: 150px;" class="text-end">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% if cars.is_empty() %}
						<tr>
							<td colspan="6" class="text-center py-5 text-muted">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor" class="mb-3 text-secondary" style="width: 48px; height: 48px;"><path d="M224.61-220v37.69q0 17.63-12.35 29.97t-30 12.34q-17.64 0-29.95-12.34Q140-164.68 140-182.31v-282.15q0-6.23.81-12.46t2.72-11.94l71.63-202.52q7.19-21.61 26.06-35.11Q260.09-740 283.46-740h393.08q23.37 0 42.24 13.51 18.87 13.5 26.06 35.11l71.63 202.52q1.91 5.71 2.72 11.94.81 6.23.81 12.46v282.15q0 17.63-12.35 29.97-12.36 12.34-30 12.34-17.65 0-29.96-12.34-12.3-12.34-12.3-29.97V-220H224.61Zm-.3-316.92h511.38l-47.38-135q-1.54-3.85-4.62-5.96-3.08-2.12-7.31-2.12H283.62q-4.23 0-7.31 2.12-3.08 2.11-4.62 5.96l-47.38 135Zm-24.31 60V-280v-196.92Zm98.55 150.77q21.83 0 37.03-15.29 15.19-15.28 15.19-37.11t-15.28-37.03q-15.29-15.19-37.12-15.19t-37.02 15.28q-15.2 15.29-15.2 37.12t15.29 37.02q15.28 15.2 37.11 15.2Zm363.08 0q21.83 0 37.02-15.29 15.2-15.28 15.2-37.11t-15.29-37.03q-15.28-15.19-37.11-15.19t-37.03 15.28q-15.19 15.29-15.19 37.12t15.28 37.02q15.29 15.2 37.12 15.2ZM200-280h560v-196.92H200V-280Z"/></svg>
								<div class="fs-6 fw-semibold text-dark-emphasis mb-1">No Cars Found</div>
								<div>Add a car on the right side to get started.</div>
							</td>
						</tr>
						{% else %}
							{% for item in cars %}
							<tr id="car-row-{{ item.car.car_id }}">
								<td class="font-monospace fw-semibold">#{{ item.car.car_id }}</td>
								<td class="fw-semibold">{{ item.car.name }}</td>
								<td>
									<span class="font-monospace">
										{{ item.car.police_number }}
									</span>
								</td>
								<td>
									{% if let crate::entities::sea_orm_active_enums::CarType::Passenger = item.car.car_type %}
										<span class="badge bg-success px-2 py-1 rounded-pill fw-semibold">
											Passenger
										</span>
									{% else %}
										<span class="badge bg-primary px-2 py-1 rounded-pill fw-semibold">
											Delivery
										</span>
									{% endif %}
								</td>
								<td>
									{% if let Some(tracker) = item.tracker %}
										<span class="badge bg-success px-2 py-1 rounded-pill fw-semibold">
											{{ tracker.name }}
										</span>
									{% else %}
										<span class="badge bg-secondary px-2 py-1 rounded-pill fw-semibold">Unassigned</span>
									{% endif %}
								</td>
								<td class="text-end">
									<div class="d-flex gap-2 justify-content-end">
										<button hx-get="/crud/cars?edit={{ item.car.car_id }}&page={{ current_page }}" hx-target="body" hx-swap="innerHTML" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-2" title="Edit">
											<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor" style="width: 16px; height: 16px;"><path d="M200-200h50.46l409.46-409.46-50.46-50.46L200-250.46V-200Zm-23.84 60q-15.37 0-25.76-10.4-10.4-10.39-10.4-25.76v-69.3q0-14.63 5.62-27.89 5.61-13.26 15.46-23.11l506.54-506.31q9.07-8.24 20.03-12.73 10.97-4.5 23-4.5t23.3 4.27q11.28 4.27 19.97 13.58l48.85 49.46q9.31 8.69 13.27 20 3.96 11.31 3.96 22.62 0 12.07-4.12 23.03-4.12 10.97-13.11 20.04L296.46-161.08q-9.85 9.85-23.11 15.46-13.26 5.62-27.89 5.62h-69.3Zm584.22-570.15-50.23-50.23 50.23 50.23Zm-126.13 75.9-24.79-25.67 50.46 50.46-25.67-24.79Z"/></svg>
											Edit
										</button>
										<button class="btn btn-sm btn-outline-danger d-inline-flex align-items-center gap-2"
											hx-delete="/crud/cars/{{ item.car.car_id }}?page={{ current_page }}"
											hx-target="body"
											hx-swap="innerHTML"
											hx-confirm="Are you sure you want to delete car '{{ item.car.name }}'?"
											title="Delete">
											<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor" style="width: 16px; height: 16px;"><path d="M292.31-140q-29.83 0-51.07-21.24Q220-182.48 220-212.31V-720h-10q-12.75 0-21.37-8.63-8.63-8.63-8.63-21.38 0-12.76 8.63-21.37Q197.25-780 210-780h150q0-14.69 10.35-25.04 10.34-10.34 25.03-10.34h169.24q14.69 0 25.03 10.34Q600-794.69 600-780h150q12.75 0 21.37 8.63 8.63 8.63 8.63 21.38 0 12.76-8.63 21.37Q762.75-720 750-720h-10v507.69q0 29.83-21.24 51.07Q697.52-140 667.69-140H292.31ZM680-720H280v507.69q0 5.39 3.46 8.85t8.85 3.46h375.38q5.39 0 8.85-3.46t3.46-8.85V-720ZM427.54-288.62q8.61-8.63 8.61-21.38v-300q0-12.75-8.63-21.38-8.62-8.62-21.38-8.62-12.75 0-21.37 8.62-8.61 8.63-8.61 21.38v300q0 12.75 8.62 21.38 8.63 8.62 21.39 8.62 12.75 0 21.37-8.62Zm147.69 0q8.61-8.63 8.61-21.38v-300q0-12.75-8.62-21.38-8.63-8.62-21.39-8.62-12.75 0-21.37 8.62-8.61 8.63-8.61 21.38v300q0 12.75 8.63 21.38 8.62 8.62 21.38 8.62 12.75 0 21.37-8.62ZM280-720v520-520Z"/></svg>
											Delete
										</button>
									</div>
								</td>
							</tr>
							{% endfor %}
						{% endif %}
					</tbody>
				</table>
			</div>

			{% if total_pages > 1 %}
			<div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
				<div class="text-muted small">
					Page {{ current_page }} of {{ total_pages }}
				</div>
				<nav aria-label="Table navigation">
					<ul class="pagination pagination-sm mb-0">
						<!-- Previous Page -->
						<li class="page-item {% if current_page == 1 %}disabled{% endif %}">
							<button class="page-link" 
								hx-get="/crud/cars?page={{ current_page - 1 }}{% if let Some(e) = editing_car %}&edit={{ e.car_id }}{% endif %}" 
								hx-target="body" 
								hx-swap="innerHTML"
								{% if current_page == 1 %}disabled{% endif %}>
								Previous
							</button>
						</li>
						
						<!-- Page Numbers -->
						{% for p in pages %}
						<li class="page-item {% if *p == current_page %}active{% endif %}">
							<button class="page-link" 
								hx-get="/crud/cars?page={{ p }}{% if let Some(e) = editing_car %}&edit={{ e.car_id }}{% endif %}" 
								hx-target="body" 
								hx-swap="innerHTML">
								{{ p }}
							</button>
						</li>
						{% endfor %}
						
						<!-- Next Page -->
						<li class="page-item {% if current_page == total_pages %}disabled{% endif %}">
							<button class="page-link" 
								hx-get="/crud/cars?page={{ current_page + 1 }}{% if let Some(e) = editing_car %}&edit={{ e.car_id }}{% endif %}" 
								hx-target="body" 
								hx-swap="innerHTML"
								{% if current_page == total_pages %}disabled{% endif %}>
								Next
							</button>
						</li>
					</ul>
				</nav>
			</div>
			{% endif %}
		</div>
	</div>

	<!-- CRUD Form -->
	<div class="col-12 col-lg-4">
		<div class="card border-0 shadow-sm p-4 h-100 d-flex flex-column gap-4">
			{% if let Some(editing) = editing_car %}
				<div class="d-flex align-items-center justify-content-between">
					<h5 class="fw-bold text-dark">Edit Car</h5>
					<span class="badge rounded-pill bg-primary px-3 py-2 fw-semibold">ID #{{ editing.car_id }}</span>
				</div>

				<form hx-put="/crud/cars/{{ editing.car_id }}?page={{ current_page }}" hx-target="body" hx-swap="innerHTML">
					<div class="mb-3">
						<label for="car-name" class="form-label fw-semibold text-muted">Car Name / Model</label>
						<input type="text" class="form-control form-control-lg" id="car-name" name="name" value="{{ editing.name }}" placeholder="e.g. Grandmax" required>
					</div>
					<div class="mb-3">
						<label for="car-police" class="form-label fw-semibold text-muted">License Plate</label>
						<input type="text" class="form-control form-control-lg" id="car-police" name="police_number" value="{{ editing.police_number }}" placeholder="e.g. B 1234 ABC" required>
					</div>
					<div class="mb-3">
						<label for="car-type" class="form-label fw-semibold text-muted">Car Type</label>
						<select class="form-select form-select-lg" id="car-type" name="car_type" required>
							<option value="Passenger" {% if let crate::entities::sea_orm_active_enums::CarType::Passenger = editing.car_type %}selected{% endif %}>Passenger</option>
							<option value="Delivery" {% if let crate::entities::sea_orm_active_enums::CarType::Delivery = editing.car_type %}selected{% endif %}>Delivery</option>
						</select>
					</div>
					<div class="mb-3">
						<label for="car-tracker" class="form-label fw-semibold text-muted">Assign GPS Tracker</label>
						<select class="form-select form-select-lg" id="car-tracker" name="tracker_id">
							<option value="">Unassigned</option>
							{% for tracker in available_trackers %}
								<option value="{{ tracker.tracker_id }}" {% if let Some(tid) = editing.tracker_id %}{% if *tid == tracker.tracker_id %}selected{% endif %}{% endif %}>
									{{ tracker.name }}
								</option>
							{% endfor %}
						</select>
					</div>
					<div class="d-grid gap-2">
						<button type="submit" class="btn btn-primary btn-lg fs-6">Save Changes</button>
						<button hx-get="/crud/cars?page={{ current_page }}" hx-target="body" hx-swap="innerHTML" class="btn btn-light border btn-lg fs-6">Cancel</button>
					</div>
				</form>
			{% else %}
				<h5 class="fw-bold text-dark">Add New Car</h5>

				<form hx-post="/crud/cars" hx-target="body" hx-swap="innerHTML">
					<div class="mb-3">
						<label for="car-name" class="form-label fw-semibold text-muted">Car Name / Model</label>
						<input type="text" class="form-control form-control-lg" id="car-name" name="name" placeholder="e.g. Grandmax" required>
					</div>
					<div class="mb-3">
						<label for="car-police" class="form-label fw-semibold text-muted">License Plate</label>
						<input type="text" class="form-control form-control-lg" id="car-police" name="police_number" placeholder="e.g. B 1234 ABC" required>
					</div>
					<div class="mb-3">
						<label for="car-type" class="form-label fw-semibold text-muted">Car Type</label>
						<select class="form-select form-select-lg" id="car-type" name="car_type" required>
							<option value="Passenger" selected>Passenger</option>
							<option value="Delivery">Delivery</option>
						</select>
					</div>
					<div class="mb-3">
						<label for="car-tracker" class="form-label fw-semibold text-muted">Assign GPS Tracker</label>
						<select class="form-select form-select-lg" id="car-tracker" name="tracker_id">
							<option value="" selected>Unassigned</option>
							{% for tracker in available_trackers %}
								<option value="{{ tracker.tracker_id }}">{{ tracker.name }}</option>
							{% endfor %}
						</select>
					</div>
					<div class="d-grid">
						<button type="submit" class="btn btn-primary btn-lg fs-6">Add Car</button>
					</div>
				</form>
			{% endif %}
		</div>
	</div>
</div>
{% endblock %}
