{% extends "template.html" %}

{% block head %}
	<title>Live Tracking - Poolcar</title>
{% endblock %}

{% block body %}
{% if let Some(err) = error %}
<div class="alert alert-danger border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert">
	<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 -960 960 960"><path d="M480-280q17 0 28.5-11.5T520-320q0-17-11.5-28.5T480-360q-17 0-28.5 11.5T440-320q0 17 11.5 28.5T480-280Zm-40-160h80v-240h-80v240Zm40 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>
	<div>{{ err }}</div>
</div>
{% endif %}

<!-- Page Header & Focus Selector -->
<div class="d-flex flex-column gap-3 mb-2">
	<h3 class="fw-bold mb-0">Live Tracking</h3>
	<div style="max-width: 560px;">
		<label for="focus-tracker" class="form-label fw-semibold mb-3">Focus Tracker</label>
		<select class="form-select" id="focus-tracker">
			<option value="" selected>Show All Trackers</option>
			{% for tracker in trackers %}
				{% if let Some(payload) = self.get_payload(tracker.tracker.tracker_id) %}
					{% if let (Some(lat), Some(lng)) = (payload.location.latitude, payload.location.longitude) %}
						<option value="{{ tracker.tracker.tracker_id }}"
								data-lat="{{ lat }}"
								data-lng="{{ lng }}"
								data-car-type="{% if let Some(car) = tracker.car %}{{ car.car_type.as_str() }}{% else %}passenger{% endif %}">
							{{ tracker.tracker.name }}
							{% if let Some(car) = tracker.car %}
								({{ car.name }} - {{ car.police_number }})
							{% endif %}
						</option>
					{% endif %}
				{% else %}
					<option value="{{ tracker.tracker.tracker_id }}" disabled>
						{{ tracker.tracker.name }}
						{% if let Some(car) = tracker.car %}
							({{ car.name }} - {{ car.police_number }})
						{% endif %}
						(No Signal)
					</option>
				{% endif %}
			{% endfor %}
		</select>
	</div>
</div>

<!-- Map Container -->
<div class="rounded-4 overflow-hidden border border-secondary-subtle" style="height: calc(100vh - 280px); width: 100%; position: relative;">
	<div id="live-map" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; z-index: 1;"></div>
</div>

<div id="active-trips-data" style="display: none;">
	{% for trip in active_trips %}
		<div class="trip-destination"
			 data-activity-id="{{ trip.trip.activity_id }}"
			 data-lat="{{ trip.contact_latitude }}"
			 data-lng="{{ trip.contact_longitude }}"
			 data-desc="{% if let Some(desc) = trip.trip.description.clone() %}{{ desc }}{% else %}No Description{% endif %}">
		</div>
	{% endfor %}
</div>

<script>
(function() {
	function initLiveMap() {
		const mapElement = document.getElementById('live-map');
		if (!mapElement) return;

		const homeLat = -6.370901936057233;
		const homeLng = 106.82459298887727;
		const homeIcon = L.icon({
			iconUrl: '/assets/home.png',
			iconSize: [42, 42],
			iconAnchor: [21, 21],
			popupAnchor: [0, -15]
		});
		const colors = ['1d00ff', '00ff0e', 'cc0000', 'ff33e1', '0074cc', 'ffda00', 'ff8300', '28cc6a', 'ff3378', '00bdff'];
		const map = L.map('live-map').setView([homeLat, homeLng], 13);

		// Initialize Map
		if (window.liveMapInstance) {
			try {
				window.liveMapInstance.off();
				window.liveMapInstance.remove();
			} catch (e) {
				console.error('Error removing map:', e);
			}
			window.liveMapInstance = null;
		}
		window.liveMapInstance = map;
		mapElement.addEventListener('htmx:beforeCleanupElement', function() {
			if (window.liveMapInstance) {
				try {
					window.liveMapInstance.off();
					window.liveMapInstance.remove();
				} catch (e) {
					console.error('Error removing map:', e);
				}
				window.liveMapInstance = null;
			}
		});
		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			maxZoom: 19,
			attribution: '© OpenStreetMap'
		}).addTo(map);
		L.marker([homeLat, homeLng], { icon: homeIcon }).addTo(map).bindPopup('Politeknik Negeri Jakarta');

		// Initialize Tracker Marker
		const markers = {};
		const destinationMarkers = {};
		const allLatLngs = [[homeLat, homeLng]];

		function recalculateBounds() {
			const newLatLngs = [[homeLat, homeLng]];
			for (const key in markers) {
				newLatLngs.push(markers[key].getLatLng());
			}
			for (const key in destinationMarkers) {
				newLatLngs.push(destinationMarkers[key].getLatLng());
			}
			allLatLngs.length = 0;
			newLatLngs.forEach(ll => allLatLngs.push(ll));
		}

		const selectElement = document.getElementById('focus-tracker');
		if (selectElement) {
			Array.from(selectElement.options).forEach(opt => {
				const id = opt.value;
				if (!id) return;

				const latStr = opt.getAttribute('data-lat');
				const lngStr = opt.getAttribute('data-lng');

				if (latStr && lngStr) {
					const lat = parseFloat(latStr);
					const lng = parseFloat(lngStr);
					if (!isNaN(lat) && !isNaN(lng)) {
						const carType = opt.getAttribute('data-car-type');
						const colorIndex = parseInt(id || '0');
						const color = colors[colorIndex % colors.length];
						const trackerIcon = L.icon({
							iconUrl: `/assets/${carType}-${color}.png`,
							iconSize: [31, 46],
							iconAnchor: [15.5, 46],
							popupAnchor: [0, -40]
						});

						const marker = L.marker([lat, lng], { icon: trackerIcon })
							.addTo(map)
							.bindPopup(`<strong>${opt.text}</strong>`);
						markers[id] = marker;
						allLatLngs.push([lat, lng]);
					}
				}
			});
		}

		// Initialize Trip Marker
		const tripDestinations = document.querySelectorAll('.trip-destination');
		tripDestinations.forEach(el => {
			const activityId = el.getAttribute('data-activity-id');
			const latStr = el.getAttribute('data-lat');
			const lngStr = el.getAttribute('data-lng');
			const desc = el.getAttribute('data-desc') || 'Destination';

			if (latStr && lngStr) {
				const lat = parseFloat(latStr);
				const lng = parseFloat(lngStr);
				if (!isNaN(lat) && !isNaN(lng)) {
					const flagIcon = L.icon({
						iconUrl: '/assets/flag.png',
						iconSize: [31, 46],
						iconAnchor: [15.5, 46],
						popupAnchor: [0, -40]
					});

					const marker = L.marker([lat, lng], { icon: flagIcon })
						.addTo(map)
						.bindPopup(`<strong>${desc}</strong>`);

					if (activityId) {
						destinationMarkers[activityId] = marker;
					}
					allLatLngs.push([lat, lng]);
				}
			}
		});

		// Fit bounds initially if we have trackers
		if (allLatLngs.length > 1) {
			map.fitBounds(L.latLngBounds(allLatLngs), { padding: [50, 50] });
		}

		// Dropdown to focus into tracker
		function handleFocusChange() {
			const selectedOption = selectElement.options[selectElement.selectedIndex];
			const id = selectedOption.value;

			if (id) {
				const marker = markers[id];
				if (marker) {
					const latLng = marker.getLatLng();
					map.setView(latLng, 16);
					marker.openPopup();
				}
			} else {
				if (allLatLngs.length > 1) {
					map.fitBounds(L.latLngBounds(allLatLngs), { padding: [50, 50] });
				} else {
					map.setView([homeLat, homeLng], 13);
				}
			}
		}

		if (selectElement) {
			selectElement.addEventListener('change', handleFocusChange);
		}

		// Setup WebSocket
		const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
		const wsUrl = `${protocol}//${window.location.host}/ws/live`;
		const socket = new WebSocket(wsUrl);

		socket.onmessage = function(event) {
			try {
				const message = JSON.parse(event.data);
				if (message.message_type === 'tracker_location') {
					const payload = message.data;
					const trackerId = payload.id;

					if (payload.location && payload.location.latitude !== null && payload.location.longitude !== null) {
						const lat = payload.location.latitude;
						const lng = payload.location.longitude;

						// Also update dropdown
						const opt = selectElement ? selectElement.querySelector(`option[value="${trackerId}"]`) : null;
						if (opt) {
							opt.setAttribute('data-lat', lat);
							opt.setAttribute('data-lng', lng);

							if (opt.disabled) {
								opt.disabled = false;
								opt.text = opt.text.replace(/\s*\(No\s+Signal\)/i, '');
							}
						}

						let marker = markers[trackerId];
						if (marker) {
							marker.setLatLng([lat, lng]);
						} else {
							const carType = opt ? (opt.getAttribute('data-car-type') || 'passenger') : 'passenger';
							const color = colors[trackerId % colors.length];

							const customIcon = L.icon({
								iconUrl: `/assets/${carType}-${color}.png`,
								iconSize: [31, 46],
								iconAnchor: [15.5, 46],
								popupAnchor: [0, -40]
							});

							marker = L.marker([lat, lng], { icon: customIcon })
								.addTo(map)
								.bindPopup(`<strong>${opt ? opt.text : 'Tracker ' + trackerId}</strong>`);
							markers[trackerId] = marker;
						}

						recalculateBounds();

						// Continue focus
						if (selectElement && selectElement.value === String(trackerId)) {
							map.setView([lat, lng], 16);
						}
					}
				} else if (message.message_type === 'update_destination') {
					const payload = message.data;
					const activityId = payload.activity_id;
					const lat = parseFloat(payload.contact_latitude);
					const lng = parseFloat(payload.contact_longitude);
					const desc = payload.contact_name || 'No Description';

					if (!isNaN(lat) && !isNaN(lng)) {
						let marker = destinationMarkers[activityId];
						if (marker) {
							marker.setLatLng([lat, lng]);
							marker.setPopupContent(`<strong>${desc}</strong>`);
						} else {
							const flagIcon = L.icon({
								iconUrl: '/assets/flag.png',
								iconSize: [31, 46],
								iconAnchor: [15.5, 46],
								popupAnchor: [0, -40]
							});
							marker = L.marker([lat, lng], { icon: flagIcon })
								.addTo(map)
								.bindPopup(`<strong>${desc}</strong>`);
							destinationMarkers[activityId] = marker;
						}
						recalculateBounds();
					}
				} else if (message.message_type === 'remove_destination') {
					const payload = message.data;
					const activityId = payload.activity_id;
					const marker = destinationMarkers[activityId];
					if (marker) {
						map.removeLayer(marker);
						delete destinationMarkers[activityId];
						recalculateBounds();
					}
				}
			} catch (e) {
				console.error('Error handling WebSocket message:', e);
			}
		};

		socket.onclose = function() {
			console.log('Live WebSocket connection closed');
		};

		socket.onerror = function(err) {
			console.error('Live WebSocket error:', err);
		};

		mapElement.addEventListener('htmx:beforeCleanupElement', function() {
			try {
				socket.close();
			} catch (e) {
				console.error('Error closing WebSocket:', e);
			}
		});
	}

	initLiveMap();
})();
</script>
{% endblock %}
